{
  "$id": "citable://schemas/prompt-result.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Prompt test observation",
  "type": "object",
  "required": ["observation_id", "prompt_id", "engine", "prompt_text", "date_time", "locale"],
  "properties": {
    "observation_id": { "type": "string" },
    "prompt_id": { "type": "string" },
    "engine": { "type": "string" },
    "model": { "type": ["string", "null"] },
    "interface": { "type": "string" },
    "account_state": { "type": "string", "enum": ["clean", "logged_in", "controlled", "unknown"] },
    "authentication_state": { "type": "string" },
    "location": { "type": "string" },
    "locale": { "type": "string" },
    "language": { "type": "string" },
    "date_time": { "type": "string" },
    "prompt_text": { "type": "string" },
    "prompt_variant": { "type": ["string", "null"] },
    "follow_up_context": { "type": ["string", "null"] },
    "answer_text": { "type": "string" },
    "retrieved_sources": { "type": "array", "items": { "type": "string" } },
    "citations": { "type": "array", "items": { "type": "string" } },
    "mention_status": { "type": "string", "enum": ["mentioned", "not_mentioned", "ambiguous"] },
    "recommendation_status": { "type": "string", "enum": ["recommended", "conditionally_recommended", "not_recommended", "not_applicable", "ambiguous"] },
    "position": { "type": ["integer", "null"] },
    "factual_accuracy": { "type": "string", "enum": ["accurate", "partially_accurate", "inaccurate", "not_assessed"] },
    "entity_confusion": { "type": "boolean" },
    "material_omissions": { "type": "array", "items": { "type": "string" } },
    "sentiment": { "type": "string", "enum": ["positive", "neutral", "negative", "mixed", "not_assessed"] },
    "run_index": { "type": "integer", "minimum": 1 },
    "runs_in_series": { "type": "integer", "minimum": 1 },
    "variance_notes": { "type": ["string", "null"] },
    "evaluator": { "type": "string" }
  }
}
