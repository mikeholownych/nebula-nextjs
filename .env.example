# Platform API Configuration
# Copy to .env and fill in values

# Environment
ENVIRONMENT=development

# Database (PostgreSQL)
DATABASE_URL=postgresql+psycopg:///nebula_platform?host=/var/run/postgresql&port=5433&user=postgres

# Redis
REDIS_URL=redis://localhost:6379/0

# Google OAuth 2.0
GOOGLE_CLIENT_ID=625346353182-qnlo095vhh5h8f8m1mkemjrrogppl821.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

# JWT Configuration
SECRET_KEY=generate_with_python_secrets_token_urlsafe_32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=7

# Stripe (already configured in main nebula)
STRIPE_SECRET_KEY=from_main_env
STRIPE_WEBHOOK_SECRET=from_main_env

# SendGrid (for magic links)
SENDGRID_API_KEY=optional_for_now
SENDGRID_FROM_EMAIL=noreply@nebulacomponents.shop

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://nebulacomponents.shop
